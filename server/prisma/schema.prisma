datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id     String  @id @default(uuid())
  name   String
  role   String  @default("child")
  chores Chore[]
}

model ChoreTemplate {
  id          String   @id @default(uuid())
  title       String
  baseValue   Float
  isMandatory Boolean  @default(false)
}

model Chore {
  id            String   @id @default(uuid())
  title         String
  baseValue     Float
  isMandatory   Boolean  @default(false)
  templateId    String?
  assignedTo    String
  completedDays String[]
  isApproved    Boolean  @default(false)
  isArchived    Boolean  @default(false)
  user          User     @relation(fields: [assignedTo], references: [id], onDelete: Cascade)
}

model PayoutRecord {
  id         String   @id @default(uuid())
  childId    String
  childName  String
  amount     Float
  timestamp  DateTime @default(now())
  choresPaid String[]
}

model Parent {
  id                String   @id @default(uuid())
  username          String   @unique
  password          String
  hasChanged        Boolean  @default(false)
  allowedEmails     String[] @default([])
  oauthIssuer       String?
  oauthClientId     String?
  oauthClientSecret String?
}

model CashPayment {
  id        String   @id @default(uuid())
  childId   String
  childName String
  amount    Float
  note      String?
  timestamp DateTime @default(now())
}

// ── Rewards & Points System ───────────────────────────────────────────────────

model RewardTemplate {
  id          String   @id @default(uuid())
  title       String
  description String?
  pointCost   Int
  icon        String?
  isActive    Boolean  @default(true)
  isCustom    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model PointLedger {
  id        String   @id @default(uuid())
  childId   String
  amount    Int
  reason    String
  choreId   String?
  createdAt DateTime @default(now())
}

model RewardRedemption {
  id               String   @id @default(uuid())
  childId          String
  childName        String
  rewardTemplateId String
  rewardTitle      String
  pointCost        Int
  timestamp        DateTime @default(now())
}

model RewardRequest {
  id          String   @id @default(uuid())
  childId     String
  childName   String
  title       String
  description String?
  status      String   @default("pending")
  pointCost   Int?
  createdAt   DateTime @default(now())
}

model RedemptionRequest {
  id               String   @id @default(uuid())
  childId          String
  childName        String
  rewardTemplateId String
  rewardTitle      String
  pointCost        Int
  status           String   @default("pending")
  timestamp        DateTime @default(now())
}

model NotificationSettings {
  id                   String  @id @default("singleton")
  pushoverAppToken     String?
  pushoverUserKey      String?
  pushoverEnabled      Boolean @default(false)
  smtpHost             String?
  smtpPort             Int?
  smtpUser             String?
  smtpPassword         String?
  smtpFrom             String?
  smtpEnabled          Boolean @default(false)
  notifyChoreComplete  Boolean @default(true)
  notifyStreakBonus    Boolean @default(true)
  notifyRewardRequest  Boolean @default(true)
  notifyRewardIdea     Boolean @default(true)
  notifyWeeklyReset    Boolean @default(true)
  notifyRewardApproved Boolean @default(true)
}
