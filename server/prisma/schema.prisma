datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id     String  @id @default(uuid())
  name   String
  role   String  @default("child")
  chores Chore[]
}

model ChoreTemplate {
  id          String   @id @default(uuid())
  title       String
  baseValue   Float
  isMandatory Boolean  @default(false)
}

model Chore {
  id            String   @id @default(uuid())
  title         String
  baseValue     Float
  isMandatory   Boolean  @default(false)
  templateId    String?
  assignedTo    String
  completedDays String[]
  isApproved    Boolean  @default(false)
  isArchived    Boolean  @default(false)
  user          User     @relation(fields: [assignedTo], references: [id], onDelete: Cascade)
}

model PayoutRecord {
  id         String   @id @default(uuid())
  childId    String
  childName  String
  amount     Float
  timestamp  DateTime @default(now())
  choresPaid String[]
}

model Parent {
  id         String @id @default(uuid())
  username   String @unique
  password   String
  hasChanged Boolean @default(false)
}
