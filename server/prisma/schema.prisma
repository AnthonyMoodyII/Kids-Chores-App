datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id     String  @id @default(uuid())
  name   String
  role   String  @default("child")
  chores Chore[]
}

model ChoreTemplate {
  id          String   @id @default(uuid())
  title       String
  baseValue   Float
  isMandatory Boolean  @default(false)
  maxPerDay   Int      @default(1)
  isInPool    Boolean  @default(true)
  icon        String?
}

model Chore {
  id            String   @id @default(uuid())
  title         String
  baseValue     Float
  isMandatory   Boolean  @default(false)
  templateId    String?
  assignedTo    String
  completedDays String[]
  isApproved    Boolean  @default(false)
  isArchived    Boolean  @default(false)
  icon          String?
  user          User     @relation(fields: [assignedTo], references: [id], onDelete: Cascade)
}

model PayoutRecord {
  id         String   @id @default(uuid())
  childId    String
  childName  String
  amount     Float
  timestamp  DateTime @default(now())
  choresPaid String[]
}

model Parent {
  id                String   @id @default(uuid())
  username          String   @unique
  password          String
  hasChanged        Boolean  @default(false)
  allowedEmails     String[] @default([])
  oauthIssuer       String?
  oauthClientId     String?
  oauthClientSecret String?
}

model OAuthProvider {
  id           String   @id @default(uuid())
  name         String
  issuer       String
  clientId     String
  clientSecret String
  enabled      Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model CashPayment {
  id        String   @id @default(uuid())
  childId   String
  childName String
  amount    Float
  note      String?
  timestamp DateTime @default(now())
}

// ── Rewards & Points System ───────────────────────────────────────────────────

model RewardTemplate {
  id          String   @id @default(uuid())
  title       String
  description String?
  pointCost   Int
  icon        String?
  isActive    Boolean  @default(true)
  isCustom    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model PointLedger {
  id        String   @id @default(uuid())
  childId   String
  amount    Int
  reason    String
  choreId   String?
  createdAt DateTime @default(now())
}

model RewardRedemption {
  id               String    @id @default(uuid())
  childId          String
  childName        String
  rewardTemplateId String
  rewardTitle      String
  pointCost        Int
  timestamp        DateTime  @default(now())
  usedAt           DateTime? // null = in inventory; set = used/redeemed
  useApprovalToken String?   @unique // one-time token for parent to approve "use" request
}

model RewardRequest {
  id          String   @id @default(uuid())
  childId     String
  childName   String
  title       String
  description String?
  status      String   @default("pending")
  pointCost   Int?
  createdAt   DateTime @default(now())
}

model RedemptionRequest {
  id               String   @id @default(uuid())
  childId          String
  childName        String
  rewardTemplateId String
  rewardTitle      String
  pointCost        Int
  status           String   @default("pending")
  timestamp        DateTime @default(now())
  approvalToken    String?  @unique // one-time token for deep-link approval
}

// ── Optional Chore Pool ───────────────────────────────────────────────────────

model DailyChoreSelection {
  id          String   @id @default(uuid())
  childId     String
  childName   String
  templateId  String
  title       String
  baseValue   Float
  maxPerDay   Int      @default(1)
  icon        String?
  day         String
  weekOf      String
  completions Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([childId, templateId, day, weekOf])
}

model NotificationProvider {
  id        String   @id @default(uuid())
  type      String   // 'gotify' | future providers
  name      String
  enabled   Boolean  @default(true)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
}

model NotificationSettings {
  id                   String  @id @default("singleton")
  pushoverAppToken     String?
  pushoverUserKey      String?
  pushoverEnabled      Boolean @default(false)
  smtpHost             String?
  smtpPort             Int?
  smtpUser             String?
  smtpPassword         String?
  smtpFrom             String?
  smtpEnabled          Boolean @default(false)
  notifyChoreComplete  Boolean @default(true)
  notifyStreakBonus    Boolean @default(true)
  notifyRewardRequest  Boolean @default(true)
  notifyRewardIdea     Boolean @default(true)
  notifyWeeklyReset    Boolean @default(true)
  notifyRewardApproved Boolean @default(true)
}
